<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
    
    <connectionStrings>
        <!-- LocalDB connection with MDF file -->
        <add name="ECommerceDB" 
             connectionString="Data Source=(LocalDB)\MSSQLLocalDB;AttachDbFilename=C:\Users\User\OneDrive\Documents\ECommerceDB.mdf;Integrated Security=True;Connect Timeout=30" 
             providerName="System.Data.SqlClient" />
    </connectionStrings>
    
    <appSettings>
        <!-- Application Settings -->
        <add key="ApplicationName" value="E-Commerce System" />
        <add key="Version" value="1.0.0" />
    </appSettings>
</configuration>